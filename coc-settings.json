{
  "snippets.ultisnips.enable": true,
  "snippets.ultisnips.pythonPrompt": false,

  "languageserver": {
    "terraform": {
      "command": "/opt/homebrew/opt/terraform-lsp/bin/terraform-lsp",
      "filetypes": ["terraform", "hcl", "tf"],
      "rootPatterns": ["main.tf", ".terraform"],
      "initializationOptions": {},
      "settings": {}
    }
  },
  
  "yaml.schemas": {
    "kubernetes": ["*.yml", "*.yaml"],
    "https://json.schemastore.org/docker-compose.json": "docker-compose.yml",
    "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": "docker-compose*.yml",
    "https://json.schemastore.org/rails": ["*.yml"]
  },
  "yaml.format.enable": true,
  "yaml.validate": true,
  "yaml.completion": true,
  "yaml.hover": true,

  "json.schemas": [
    {
      "fileMatch": [
        "/*.yaml",
        "/*.yml"
      ],
      "url": "https://raw.githubusercontent.com/garethr/kubernetes-json-schema/master/v0.18.0-standalone-strict/all.json"
    }
  ],
  
  "prettier.enable": true,
  "prettier.requireConfig": false,
  "[yaml]": {
    "editor.formatOnSave": true
  }
}


